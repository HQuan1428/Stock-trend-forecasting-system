# Copy this file to .env and fill in the values you actually have.
# .env is git-ignored (see .gitignore) — never commit real secrets.
# Every variable below is optional: the main pipeline (src/runner.py)
# runs fully offline/keyless without any of them. They only unlock the
# manual, credential-gated scripts under scripts/data_sources/.

# --- Kaggle (scripts/data_sources/fetch_kaggle_news.py) ---
# Free sign-up + token: https://www.kaggle.com/settings -> Create New API Token
# Alternative to these two vars: place the downloaded kaggle.json at
# ~/.kaggle/kaggle.json (chmod 600) instead.
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Hugging Face Hub (src/finbert_sentiment.py) ---
# Optional. Without it, downloading ProsusAI/finbert weights on first run
# uses unauthenticated (rate-limited) requests. Free token:
# https://huggingface.co/settings/tokens
HF_TOKEN=
